<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Home Page</title>

    <style>
      .blog-card {
        height: 100%;
      }

.blog-card img {
  height: 220px;
  width: 100%;
  object-fit: contain;
  background-color: #f8f9fa;
} 

      .blog-card .card-body {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .blog-card .card-title {
        min-height: 48px;
      }
    </style>
</head>
<body>

    <%- include("./partials/nav") %>

    <div class="container mt-4">
      <div class="row g-4">
        <% blogs.forEach(blog => { %>
          <div class="col-lg-3 col-md-6 col-sm-12">
            <div class="card blog-card shadow-sm">
              <img 
                src="<%= blog.coverImageURL || 'https://via.placeholder.com/286x220' %>" 
                class="card-img-top" 
                alt="Blog Image"
              >
              <div class="card-body">
                <h5 class="card-title"><%= blog.title %></h5>
                <a href="/blog/<%= blog._id %>" class="btn btn-primary mt-3">Read More</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <%- include("./partials/script") %>
</body>
</html>